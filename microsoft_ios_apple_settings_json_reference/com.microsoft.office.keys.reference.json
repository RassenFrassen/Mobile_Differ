{
  "domain": "com.microsoft.office",
  "platform": "macOS",
  "source_docs": [
    "https://learn.microsoft.com/en-us/microsoft-365-apps/mac/deploy-preferences-for-office-for-mac",
    "https://learn.microsoft.com/en-us/microsoft-365-apps/privacy/mac-privacy-preferences"
  ],
  "keys": [
    {
      "key": "OfficeAutoSignIn",
      "type": "bool"
    },
    {
      "key": "OfficeActivationEmailAddress",
      "type": "string"
    },
    {
      "key": "ShowWhatsNewOnLaunch",
      "type": "bool"
    },
    {
      "key": "ShowDocStageOnLaunch",
      "type": "bool"
    },
    {
      "key": "DefaultsToLocalOpenSave",
      "type": "bool"
    },
    {
      "key": "DisableCloudFonts",
      "type": "bool"
    }
  ]
}