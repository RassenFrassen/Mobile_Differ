<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  Domain: com.microsoft.Excel
  Purpose: Example preference-domain plist for MDM (Jamf "Application & Custom Settings" / Intune "Preference file").
  Notes:
    - Replace placeholders with your org values.
    - Remove keys you don't intend to manage.
    - Data types must match the referenced Microsoft docs.
  Excel preference example.
-->
<dict>
  <!-- Prevent Excel from trying a default decryption password when opening encrypted files -->
  <key>TryDefaultPassword</key>
  <false/>
</dict>
</plist>
